// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // נדרש לפריסה על שרתי לינוקס (למשל Vercel)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  therapist
  client
  admin
}

enum SubscriptionStatus {
  none
  active
  past_due
  canceled
}

/** הרשמה: מסלול שנבחר בעת ההרשמה */
enum RegistrationPersona {
  therapist
  student
  interested
}

/** אישור מטפל חדש (תעודה) — אדמין */
enum TherapistVerificationStatus {
  none
  pending_approval
  approved
  rejected
}

enum ProductType {
  zoom
  workshop
  supervision
  shelf_product
}

enum AppointmentRequestStatus {
  pending
  approved
  rejected
  cancelled
}

model User {
  id               String               @id @default(cuid())
  name             String
  email            String               @unique
  /** null for OAuth-only accounts */
  passwordHash     String?
  role             UserRole             @default(client)
  subStatus        SubscriptionStatus   @default(none) @map("sub_status")
  image            String?
  /** מסלול שנרשם אליו (מטפל/ת, סטודנט/ית, מתעניין/ת) */
  registrationPersona RegistrationPersona? @map("registration_persona")
  /** סטטוס אימות תעודה למטפלים חדשים */
  therapistVerification TherapistVerificationStatus @default(none) @map("therapist_verification")
  /** קישור https לתעודה / קובץ שהועלה (מטפל ממתין) */
  certificateUrl   String?              @map("certificate_url") @db.VarChar(512)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  therapistProfile TherapistProfile?
  clinicalLogsAsTherapist ClinicalLog[] @relation("TherapistLogs")
  clinicalLogsAsClient    ClinicalLog[] @relation("ClientLogs")
  herbalArticles HerbalArticle[]
  auditEntries   AuditLog[]           @relation("AuditActor")
  therapistProducts Product[]         @relation("TherapistProducts")
  appointmentRequestsAsTherapist AppointmentRequest[] @relation("TherapistAppointments")
  appointmentRequestsAsClient    AppointmentRequest[] @relation("ClientAppointments")
  waitlistEntries WaitlistEntry[]

  @@map("users")
}

model TherapistProfile {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  slug         String   @unique
  /** כותרת ציבורית בדף המטפל: male = מטפל בצמחי מרפא, female = מטפלת בצמחי מרפא */
  publicTherapistTitle String @default("female") @map("public_therapist_title") @db.VarChar(16)
  bio          String   @db.Text
  /** ניסיון קליני, הכשרות והשכלה — מוצג בדף הציבורי */
  clinicalExperience String? @map("clinical_experience") @db.Text
  specialty1   String   @map("specialty_1")
  specialty2   String   @map("specialty_2")
  specialty3   String   @map("specialty_3")
  /** האם לקבל פניות להשגחה מקצועית מהדף הציבורי */
  acceptsSupervisionRequests Boolean @default(false) @map("accepts_supervision_requests")
  /** מחיר לשעה בשקלים — מוצג כשההשגחה מאופשרת */
  supervisionHourlyRate Decimal? @map("supervision_hourly_rate") @db.Decimal(10, 2)
  contactInfo  Json     @map("contact_info")
  socialLinks  Json     @map("social_links")
  /** שעות זמינות שבועיות לפגישות — JSON { "0": [{ "start": "09:00", "end": "12:00" }], ... } (0=ראשון) */
  weeklyAvailability Json? @map("weekly_availability")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("therapist_profiles")
}

model ClinicalLog {
  id           String   @id @default(cuid())
  therapistId  String   @map("therapist_id")
  clientId     String   @map("client_id")
  date         DateTime
  notesImage   String?  @map("notes_image")
  formulaJson  Json     @map("formula_json")
  summary      String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  therapist User @relation("TherapistLogs", fields: [therapistId], references: [id], onDelete: Cascade)
  client    User @relation("ClientLogs", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([therapistId, date])
  @@index([clientId])
  @@map("clinical_logs")
}

model Product {
  id          String      @id @default(cuid())
  /** מפתח יציב לפריטי קטלוג מה־seed — מאפשר עדכון חוזר בלי למחוק מוצרים שיצרת ידנית */
  catalogKey  String?     @unique @map("catalog_key") @db.VarChar(64)
  therapistId String?     @map("therapist_id")
  type        ProductType
  title       String
  description String      @db.Text
  /** תגיות לחיפוש (מערך מחרוזות בעברית) */
  tags        Json?
  /** קהל יעד: therapist | student | interested */
  audience    Json?
  /** תמונת כיסוי לדוגמה / קורסים וסדנאות — https בלבד */
  imageUrl    String?     @map("image_url") @db.VarChar(512)
  /** מיקום, מועד, קישור זום, מקסימום משתתפים וכו׳ */
  metadata    Json?       @map("metadata")
  price       Decimal     @db.Decimal(10, 2)
  memberPrice Decimal     @map("member_price") @db.Decimal(10, 2)
  active      Boolean     @default(true)
  isWaitlist  Boolean     @default(true) @map("is_waitlist")
  minParticipants Int     @default(5) @map("min_participants")
  currentRegistered Int   @default(0) @map("current_registered")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  therapist User? @relation("TherapistProducts", fields: [therapistId], references: [id], onDelete: SetNull)
  waitlistEntries WaitlistEntry[]

  @@index([therapistId])
  @@map("products")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("audit_logs")
}

model HerbalArticle {
  id          String   @id @default(cuid())
  therapistId String @map("therapist_id")
  title       String
  slug        String   @unique
  /** קטגוריה לתצוגה באינדקס ובממשק הניהול */
  category    String?  @db.VarChar(128)
  excerpt     String   @db.VarChar(500)
  body        String   @db.LongText
  /** תמונה לכרטיס אינדקס — https בלבד */
  coverImageUrl String? @map("cover_image_url") @db.VarChar(512)
  tags        Json?
  audience    Json?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  therapist User @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
  @@map("herbal_articles")
}

model AppointmentRequest {
  id           String                   @id @default(cuid())
  therapistId  String                   @map("therapist_id")
  clientUserId String?                  @map("client_user_id")
  guestName    String                   @map("guest_name")
  guestEmail   String                   @map("guest_email")
  guestPhone   String?                  @map("guest_phone") @db.VarChar(64)
  slotStart    DateTime                 @map("slot_start")
  slotEnd      DateTime                 @map("slot_end")
  status       AppointmentRequestStatus @default(pending)
  note         String?                  @db.Text
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  therapist User  @relation("TherapistAppointments", fields: [therapistId], references: [id], onDelete: Cascade)
  client    User? @relation("ClientAppointments", fields: [clientUserId], references: [id], onDelete: SetNull)

  @@index([therapistId, slotStart])
  @@index([clientUserId])
  @@map("appointment_requests")
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  userId     String?  @map("user_id")
  guestEmail String   @map("guest_email")
  guestName  String?  @map("guest_name")
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, guestEmail])
  @@index([productId])
  @@map("waitlist_entries")
}

model SiteConfig {
  id String @id @default("default")

  heroSlides Json @map("hero_slides")

  /** Main title shown in header / branding */
  siteTitle    String? @map("site_title") @db.VarChar(255)
  /** Homepage vision carousel (JSON array) */
  visionSlides Json?   @map("vision_slides")

  /** Homepage hero — small line above headline (e.g. center name) */
  homeHeroMainTitle  String? @map("home_hero_main_title") @db.VarChar(255)
  /** Homepage hero — large headline */
  homeHeroHeadline   String? @map("home_hero_headline") @db.VarChar(500)
  /** Homepage hero — instructions under headline */
  homeHeroSliderHint String? @map("home_hero_slider_hint") @db.VarChar(600)

  githubUsername  String? @map("github_username") @db.VarChar(191)
  vercelUsername  String? @map("vercel_username") @db.VarChar(191)
  railwayUsername String? @map("railway_username") @db.VarChar(191)
  /** שם משתמש ב-Unsplash (לתצוגה / תיעוד) */
  unsplashUsername String? @map("unsplash_username") @db.VarChar(191)
  /** מפתח Access של Unsplash — אם ריק, משתמשים ב-UNSPLASH_ACCESS_KEY מהסביבה */
  unsplashAccessKey String? @map("unsplash_access_key") @db.VarChar(256)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}
