# Copy to `.env` and fill in values (see DEPLOY.md).

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/herbal_center"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Optional: file uploads (S3-compatible)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# Vercel Blob — חובה להעלאת תמונות בפריסה על Vercel (הדיסק שם read-only).
# ב-Vercel: Project → Storage → Create Blob Store → Connect to Project (נוסף אוטומטית BLOB_READ_WRITE_TOKEN).
# BLOB_READ_WRITE_TOKEN=

# Google OAuth (Auth.js / NextAuth — Sign in with Google)
# Preferred names (see https://authjs.dev/getting-started/providers/google):
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Or legacy:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Authorized redirect URI in Google Cloud Console:
#   {AUTH_URL}/api/auth/callback/google
# (e.g. https://your-domain.com/api/auth/callback/google)

# Payments (placeholder wiring)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Unsplash (optional — חיפוש תמונות בלוח ניהול → תוכן)
# UNSPLASH_ACCESS_KEY=

# Bootstrap admin (optional): this email is always granted admin. If unset and there are zero admins,
# the earliest registered user is promoted when they sign in or when the admin layout loads.
# SUPER_ADMIN_EMAIL=you@example.com
