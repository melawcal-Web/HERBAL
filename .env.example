# Copy to `.env` and fill in values (see DEPLOY.md).

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/herbal_center"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Optional: file uploads (S3-compatible)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# Google OAuth for Docs export (optional; see DEPLOY.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Payments (placeholder wiring)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Unsplash (optional — חיפוש תמונות בלוח ניהול → תוכן)
# UNSPLASH_ACCESS_KEY=
